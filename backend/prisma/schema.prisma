// ─── Track & Trace Enums ──────────────────────────────────

enum StopType {
  PICKUP
  DELIVERY
}

enum HookType {
  PRELOADED
  LIVE_LOAD_UNLOAD
  DROP_HOOK
}

enum TrackingEventType {
  STATUS_CHANGE
  LOCATION_UPDATE
  CHECK_CALL
  ALERT
  DOCUMENT
  NOTE
  TEMPERATURE
  GEOFENCE
}

enum LocationSource {
  ELD
  CARRIER_PORTAL
  CHECK_CALL_EMAIL
  AE_MANUAL
  GEOFENCE
}

enum AccessorialType {
  DETENTION_PU
  DETENTION_DEL
  LUMPER
  TONU
  LAYOVER
  DEADHEAD
  DRIVER_ASSIST
  REEFER_FUEL
  HAZMAT
  INSIDE_DELIVERY
  LIFTGATE
  PALLET_EXCHANGE
}

enum AccessorialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TrackingAccessLevel {
  FULL
  STATUS_ONLY
}

enum AlertLevel {
  GREEN
  YELLOW
  RED
  CRITICAL
}

// ─── Track & Trace Models ──────────────────────────────────

model LoadStop {
  id               String    @id @default(cuid())
  loadId           String    @map("load_id")
  stopNumber       Int       @map("stop_number")
  stopType         StopType  @map("stop_type")
  facilityName     String    @map("facility_name")
  address          String
  city             String
  state            String    @db.VarChar(2)
  zip              String    @db.VarChar(10)
  latitude         Decimal?  @db.Decimal(10, 7)
  longitude        Decimal?  @db.Decimal(10, 7)
  appointmentDate  DateTime? @map("appointment_date") @db.Date
  appointmentTime  String?   @map("appointment_time")
  appointmentRef   String?   @map("appointment_ref") @db.VarChar(100)
  actualArrival    DateTime? @map("actual_arrival")
  actualDeparture  DateTime? @map("actual_departure")
  detentionStart   DateTime? @map("detention_start")
  detentionMinutes Int?      @map("detention_minutes")
  hookType         HookType? @map("hook_type")
  trailerNumber    String?   @map("trailer_number") @db.VarChar(50)
  sealNumber       String?   @map("seal_number") @db.VarChar(50)
  commodity        String?
  weight           Float?
  pieces           Int?
  onTime           Boolean?  @map("on_time")
  contactName      String?   @map("contact_name")
  contactPhone     String?   @map("contact_phone")
  dwellMinutes     Int?      @map("dwell_minutes")
  isPayable        Boolean   @default(true) @map("is_payable")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  load           Load                @relation(fields: [loadId], references: [id], onDelete: Cascade)
  trackingEvents LoadTrackingEvent[]
  accessorials   LoadAccessorial[]

  @@index([loadId])
  @@index([loadId, stopNumber])
  @@map("load_stops")
}

model LoadTrackingEvent {
  id             String            @id @default(cuid())
  loadId         String            @map("load_id")
  stopId         String?           @map("stop_id")
  eventType      TrackingEventType @map("event_type")
  statusFrom     LoadStatus?       @map("status_from")
  statusTo       LoadStatus?       @map("status_to")
  latitude       Decimal?          @db.Decimal(10, 7)
  longitude      Decimal?          @db.Decimal(10, 7)
  locationCity   String?           @map("location_city") @db.VarChar(100)
  locationState  String?           @map("location_state") @db.VarChar(2)
  locationSource LocationSource?   @map("location_source")
  etaDestination DateTime?         @map("eta_destination")
  temperatureF   Decimal?          @map("temperature_f") @db.Decimal(5, 1)
  alertLevel     AlertLevel?       @map("alert_level")
  notes          String?
  createdBy      String?           @map("created_by")
  createdAt      DateTime          @default(now()) @map("created_at")

  load Load      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  stop LoadStop? @relation(fields: [stopId], references: [id])

  @@index([loadId])
  @@index([loadId, createdAt])
  @@index([eventType])
  @@index([alertLevel])
  @@map("load_tracking_events")
}

model LoadAccessorial {
  id               String            @id @default(cuid())
  loadId           String            @map("load_id")
  stopId           String?           @map("stop_id")
  type             AccessorialType
  amount           Decimal           @db.Decimal(10, 2)
  quantity         Decimal?          @db.Decimal(10, 2)
  unit             String?           @db.VarChar(20)
  rate             Decimal?          @db.Decimal(10, 2)
  status           AccessorialStatus @default(PENDING)
  approvedBy       String?           @map("approved_by")
  approvedAt       DateTime?         @map("approved_at")
  rejectedReason   String?           @map("rejected_reason")
  receiptDocId     String?           @map("receipt_document_id")
  billedTo         String?           @map("billed_to") @db.VarChar(20)
  carrierInvoiceId String?           @map("carrier_invoice_id")
  shipperInvoiceId String?           @map("shipper_invoice_id")
  notes            String?
  createdBy        String?           @map("created_by")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  load Load      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  stop LoadStop? @relation(fields: [stopId], references: [id])

  @@index([loadId])
  @@index([status])
  @@map("load_accessorials")
}

model ShipperTrackingToken {
  id             String              @id @default(cuid())
  loadId         String              @map("load_id")
  token          String              @unique @db.VarChar(12)
  shipperId      String              @map("shipper_id")
  accessLevel    TrackingAccessLevel @map("access_level")
  createdAt      DateTime            @default(now()) @map("created_at")
  expiresAt      DateTime            @map("expires_at")
  lastAccessedAt DateTime?           @map("last_accessed_at")
  accessCount    Int                 @default(0) @map("access_count")

  load Load @relation(fields: [loadId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([loadId])
  @@map("shipper_tracking_tokens")
}

// ─── Track & Trace Module (v3.3.u) ───

model LoadException {
  id               String    @id @default(cuid())
  loadId           String    @map("load_id")
  load             Load      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  category         String    @db.VarChar(100) // engine_failure, flat_tire_trailer, weather_delay, shipper_detention, etc.
  unitType         String?   @map("unit_type") @db.VarChar(20) // truck | trailer | na
  description      String?
  locationText     String?   @map("location_text")
  locationLat      Decimal?  @map("location_lat") @db.Decimal(10, 6)
  locationLng      Decimal?  @map("location_lng") @db.Decimal(10, 6)
  reportedAt       DateTime  @default(now()) @map("reported_at")
  reportedById     String?   @map("reported_by_id")
  reportedByName   String?   @map("reported_by_name")
  reportedSource   String    @default("AE_CONSOLE") @map("reported_source") @db.VarChar(20) // AE_CONSOLE | CARRIER_PORTAL
  status           String    @default("OPEN") @db.VarChar(20) // OPEN | RESOLVED
  resolvedAt       DateTime? @map("resolved_at")
  resolvedById     String?   @map("resolved_by_id")
  resolutionNotes  String?   @map("resolution_notes")
  etaImpactMinutes Int?      @map("eta_impact_minutes")

  // Repair tracking (mechanical)
  repairShopName           String?   @map("repair_shop_name")
  repairShopPhone          String?   @map("repair_shop_phone")
  repairEta                DateTime? @map("repair_eta")
  repairCost               Decimal?  @map("repair_cost") @db.Decimal(12, 2)
  repairCostResponsibility String?   @map("repair_cost_responsibility") @db.VarChar(20) // carrier | broker
  receiptStatus            String    @default("NONE") @map("receipt_status") @db.VarChar(20) // NONE | REQUESTED | UPLOADED | VERIFIED

  shipperNotified   Boolean   @default(false) @map("shipper_notified")
  shipperNotifiedAt DateTime? @map("shipper_notified_at")

  documents Document[] @relation("ExceptionDocs")

  @@index([loadId])
  @@index([status])
  @@index([category])
  @@map("load_exceptions")
}

model LoadActivity {
  id          String   @id @default(cuid())
  loadId      String   @map("load_id")
  load        Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  eventType   String   @map("event_type") @db.VarChar(64) // load_created, tender_sent, status_change, check_call_done, exception_logged, doc_uploaded, ...
  description String
  actorType   String   @default("SYSTEM") @map("actor_type") @db.VarChar(20) // USER | SYSTEM | CARRIER | DRIVER | SHIPPER
  actorId     String?  @map("actor_id")
  actorName   String?  @map("actor_name")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([loadId, createdAt])
  @@index([eventType])
  @@map("load_activity")
}

model GeofenceEvent {
  id           String   @id @default(cuid())
  loadId       String   @map("load_id")
  load         Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  eventType    String   @map("event_type") @db.VarChar(40) // entered_origin | departed_origin | entered_destination | departed_destination
  facilityName String?  @map("facility_name")
  lat          Decimal? @db.Decimal(10, 6)
  lng          Decimal? @db.Decimal(10, 6)
  occurredAt   DateTime @default(now()) @map("occurred_at")

  @@index([loadId, occurredAt])
  @@map("geofence_events")
}

model DetentionRecord {
  id             String    @id @default(cuid())
  loadId         String    @map("load_id")
  load           Load      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  locationType   String    @map("location_type") @db.VarChar(20) // origin | destination
  facilityName   String?   @map("facility_name")
  enteredAt      DateTime  @map("entered_at")
  departedAt     DateTime? @map("departed_at")
  elapsedMinutes Int?      @map("elapsed_minutes")
  billable       Boolean   @default(false)
  ratePerHour    Decimal?  @map("rate_per_hour") @db.Decimal(10, 2)
  totalCharge    Decimal   @default(0) @map("total_charge") @db.Decimal(10, 2)
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([loadId])
  @@map("detention_records")
}

// ─── ELD / Telematics Integration (Phase 5) ───

model ELDEvent {
  id              String    @id @default(cuid())
  provider        String    @db.VarChar(20) // SAMSARA, MOTIVE, OMNITRACS
  externalId      String?   @map("external_id")
  eventType       String    @map("event_type") @db.VarChar(40) // GPS_PING, HOS_CHANGE, FAULT, GEOFENCE_ENTRY
  vehicleId       String?   @map("vehicle_id")
  vehicleName     String?   @map("vehicle_name")
  driverId        String?   @map("driver_id")
  driverName      String?   @map("driver_name")
  latitude        Decimal?  @db.Decimal(10, 6)
  longitude       Decimal?  @db.Decimal(10, 6)
  speedMph        Float?    @map("speed_mph")
  heading         Float?
  engineHours     Float?    @map("engine_hours")
  odometerMiles   Float?    @map("odometer_miles")
  fuelPct         Float?    @map("fuel_pct")
  hosStatus       String?   @map("hos_status") @db.VarChar(20) // DRIVING, ON_DUTY, SLEEPER, OFF_DUTY
  hosDriveRemain  Float?    @map("hos_drive_remain")
  hosOnDutyRemain Float?    @map("hos_on_duty_remain")
  address         String?
