  reasonCode   DelayReasonCode
  description  String?
  delayMinutes Int
  reportedAt   DateTime        @default(now())
  reportedById String
  reportedBy   User            @relation("DelayReporter", fields: [reportedById], references: [id])
  resolvedAt   DateTime?
