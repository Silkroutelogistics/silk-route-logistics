  vettingType       String  @default("FULL") // FULL, FMCSA_ONLY, IDENTITY_ONLY

  createdAt DateTime @default(now())

  @@index([carrierId])
  @@index([grade])
  @@index([createdAt])
  @@map("vetting_reports")
}

