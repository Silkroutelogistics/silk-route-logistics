// ─── Track & Trace Enums ──────────────────────────────────

enum StopType {
  PICKUP
  DELIVERY
}

enum HookType {
  PRELOADED
  LIVE_LOAD_UNLOAD
  DROP_HOOK
}

enum TrackingEventType {
  STATUS_CHANGE
  LOCATION_UPDATE
  CHECK_CALL
  ALERT
  DOCUMENT
  NOTE
  TEMPERATURE
  GEOFENCE
}

enum LocationSource {
  ELD
  CARRIER_PORTAL
  CHECK_CALL_EMAIL
  AE_MANUAL
  GEOFENCE
}

enum AccessorialType {
  DETENTION_PU
  DETENTION_DEL
  LUMPER
  TONU
  LAYOVER
  DEADHEAD
  DRIVER_ASSIST
  REEFER_FUEL
  HAZMAT
  INSIDE_DELIVERY
  LIFTGATE
  PALLET_EXCHANGE
}

enum AccessorialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TrackingAccessLevel {
  FULL
  STATUS_ONLY
}

enum AlertLevel {
  GREEN
  YELLOW
  RED
  CRITICAL
}

// ─── Track & Trace Models ──────────────────────────────────

model LoadStop {
  id              String    @id @default(cuid())
  loadId          String    @map("load_id")
  stopNumber      Int       @map("stop_number")
  stopType        StopType  @map("stop_type")
  facilityName    String    @map("facility_name")
  address         String
  city            String
  state           String    @db.VarChar(2)
  zip             String    @db.VarChar(10)
  latitude        Decimal?  @db.Decimal(10, 7)
  longitude       Decimal?  @db.Decimal(10, 7)
  appointmentDate DateTime? @map("appointment_date") @db.Date
  appointmentTime String?   @map("appointment_time")
  appointmentRef  String?   @map("appointment_ref") @db.VarChar(100)
  actualArrival   DateTime? @map("actual_arrival")
  actualDeparture DateTime? @map("actual_departure")
  detentionStart  DateTime? @map("detention_start")
  detentionMinutes Int?     @map("detention_minutes")
  hookType        HookType? @map("hook_type")
  trailerNumber   String?   @map("trailer_number") @db.VarChar(50)
  sealNumber      String?   @map("seal_number") @db.VarChar(50)
  commodity       String?
  weight          Float?
  pieces          Int?
  onTime          Boolean?  @map("on_time")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  load            Load      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  trackingEvents  LoadTrackingEvent[]
  accessorials    LoadAccessorial[]

  @@index([loadId])
  @@index([loadId, stopNumber])
  @@map("load_stops")
}

model LoadTrackingEvent {
  id              String            @id @default(cuid())
  loadId          String            @map("load_id")
  stopId          String?           @map("stop_id")
  eventType       TrackingEventType @map("event_type")
  statusFrom      LoadStatus?       @map("status_from")
  statusTo        LoadStatus?       @map("status_to")
  latitude        Decimal?          @db.Decimal(10, 7)
  longitude       Decimal?          @db.Decimal(10, 7)
  locationCity    String?           @map("location_city") @db.VarChar(100)
  locationState   String?           @map("location_state") @db.VarChar(2)
  locationSource  LocationSource?   @map("location_source")
  etaDestination  DateTime?         @map("eta_destination")
  temperatureF    Decimal?          @map("temperature_f") @db.Decimal(5, 1)
  alertLevel      AlertLevel?       @map("alert_level")
  notes           String?
  createdBy       String?           @map("created_by")
  createdAt       DateTime          @default(now()) @map("created_at")

  load            Load              @relation(fields: [loadId], references: [id], onDelete: Cascade)
  stop            LoadStop?         @relation(fields: [stopId], references: [id])

  @@index([loadId])
  @@index([loadId, createdAt])
  @@index([eventType])
  @@index([alertLevel])
  @@map("load_tracking_events")
}

model LoadAccessorial {
  id               String            @id @default(cuid())
  loadId           String            @map("load_id")
  stopId           String?           @map("stop_id")
  type             AccessorialType
  amount           Decimal           @db.Decimal(10, 2)
  quantity         Decimal?          @db.Decimal(10, 2)
  unit             String?           @db.VarChar(20)
  rate             Decimal?          @db.Decimal(10, 2)
  status           AccessorialStatus @default(PENDING)
  approvedBy       String?           @map("approved_by")
  approvedAt       DateTime?         @map("approved_at")
  rejectedReason   String?           @map("rejected_reason")
  receiptDocId     String?           @map("receipt_document_id")
  billedTo         String?           @map("billed_to") @db.VarChar(20)
  carrierInvoiceId String?           @map("carrier_invoice_id")
  shipperInvoiceId String?           @map("shipper_invoice_id")
  notes            String?
  createdBy        String?           @map("created_by")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  load             Load              @relation(fields: [loadId], references: [id], onDelete: Cascade)
  stop             LoadStop?         @relation(fields: [stopId], references: [id])

  @@index([loadId])
  @@index([status])
  @@map("load_accessorials")
}

model ShipperTrackingToken {
  id              String              @id @default(cuid())
  loadId          String              @map("load_id")
  token           String              @unique @db.VarChar(12)
  shipperId       String              @map("shipper_id")
  accessLevel     TrackingAccessLevel @map("access_level")
  createdAt       DateTime            @default(now()) @map("created_at")
  expiresAt       DateTime            @map("expires_at")
  lastAccessedAt  DateTime?           @map("last_accessed_at")
  accessCount     Int                 @default(0) @map("access_count")

  load            Load                @relation(fields: [loadId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([loadId])
  @@map("shipper_tracking_tokens")
}

