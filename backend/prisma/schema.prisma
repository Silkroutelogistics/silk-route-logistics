  riskScore Int                  @default(0) // 0-100
  status    ChameleonMatchStatus @default(OPEN)

  reviewedById String?
  reviewedAt   DateTime?
  reviewNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carrierId])
  @@index([matchedCarrierId])
  @@index([status])
  @@map("chameleon_matches")
}

