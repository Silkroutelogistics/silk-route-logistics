  id              String   @id @default(cuid())
  customerId      String
  customer        Customer @relation("CustomerContractRates", fields: [customerId], references: [id], onDelete: Cascade)
  originState     String
  destState       String
  equipmentType   String
  rate            Float    // per mile
  flatRate        Float?   // flat rate alternative
  fuelSurcharge   Float    @default(0)
  minWeight       Float?
  maxWeight       Float?
  effectiveDate   DateTime
  expirationDate  DateTime
  status          ContractRateStatus @default(ACTIVE)
  volume          Int?     // expected monthly volume
  notes           String?
  createdById     String
  createdBy       User     @relation("ContractRateCreator", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([customerId])
  @@index([originState, destState, equipmentType])
  @@index([status])
  @@map("contract_rates")
}

enum ContractRateStatus {
  DRAFT
  ACTIVE
  EXPIRED
  SUSPENDED
}

// ─── RFP / Bid Management ────────────────────────────────

model RfpBid {
  id              String   @id @default(cuid())
  customerId      String
  customer        Customer @relation("CustomerRfpBids", fields: [customerId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  status          RfpStatus @default(OPEN)
  dueDate         DateTime
  lanes           Json     // array of { originState, destState, equipmentType, estimatedVolume }
  totalLanes      Int
  respondedLanes  Int      @default(0)
  responses       Json?    // array of { laneIndex, rate, notes }
  awardedAt       DateTime?
  awardedById     String?
  notes           String?
  createdById     String
  createdBy       User     @relation("RfpCreator", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([customerId])
  @@index([status])
  @@map("rfp_bids")
}

enum RfpStatus {
  DRAFT
  OPEN
  IN_REVIEW
  AWARDED
  DECLINED
  EXPIRED
}
