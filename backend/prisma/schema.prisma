}

model ELDDeviceMapping {
  id                String    @id @default(cuid())
  provider          String    @db.VarChar(20)
  externalVehicleId String    @map("external_vehicle_id")
  externalDriverId  String?   @map("external_driver_id")
  carrierId         String?   @map("carrier_id")
  driverName        String?   @map("driver_name")
  driverPhone       String?   @map("driver_phone")
  vehicleName       String?   @map("vehicle_name")
  isActive          Boolean   @default(true) @map("is_active")
  lastSeenAt        DateTime? @map("last_seen_at")
  lastLatitude      Decimal?  @map("last_latitude") @db.Decimal(10, 6)
  lastLongitude     Decimal?  @map("last_longitude") @db.Decimal(10, 6)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  carrier User? @relation(fields: [carrierId], references: [id])

  @@unique([provider, externalVehicleId])
  @@index([carrierId])
  @@map("eld_device_mappings")
}

// ─── Fraud Reporting ──────────────────────────────────────
model FraudReport {
  id        String         @id @default(cuid())
  carrierId String
  carrier   CarrierProfile @relation(fields: [carrierId], references: [id])

  reportedById String
  reportedBy   User   @relation("FraudReporter", fields: [reportedById], references: [id])

  category    FraudReportCategory
  description String
  evidence    String[] // URLs to uploaded evidence files
  loadId      String? // Optional link to the load involved

  status             FraudReportStatus @default(PENDING)
  permanentAt        DateTime? // Becomes permanent 72h after creation
  reviewedById       String?
  reviewedAt         DateTime?
  reviewNotes        String?
  carrierResponse    String? // Carrier's rebuttal
  carrierRespondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carrierId])
  @@index([status])
  @@index([category])
  @@index([reportedById])
  @@map("fraud_reports")
}

// ─── Carrier-Broker Agreement ─────────────────────────────
model CarrierAgreement {
  id        String         @id @default(cuid())
  carrierId String
  carrier   CarrierProfile @relation(fields: [carrierId], references: [id])

  version      String          @default("1.0")
  templateName String          @default("standard")
  documentUrl  String? // URL to the agreement PDF
  status       AgreementStatus @default(DRAFT)

  sentAt          DateTime?
  signedAt        DateTime?
  signedByName    String? // Full name as entered for e-signature
  signedByTitle   String? // Title (e.g. "Owner", "Manager")
  signatureData   String? // Base64 signature image or typed name
  signerIp        String? // IP address at time of signing
  signerUserAgent String?

  expiresAt         DateTime?
  terminatedAt      DateTime?
  terminatedBy      String?
  terminationReason String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([carrierId])
  @@index([status])
  @@map("carrier_agreements")
}

// ─── Contract Rate Management ────────────────────────────

model ContractRate {
  id             String             @id @default(cuid())
  customerId     String
  customer       Customer           @relation("CustomerContractRates", fields: [customerId], references: [id], onDelete: Cascade)
  originState    String
  destState      String
  equipmentType  String
  rate           Float // per mile
  flatRate       Float? // flat rate alternative
  fuelSurcharge  Float              @default(0)
  minWeight      Float?
  maxWeight      Float?
  effectiveDate  DateTime
  expirationDate DateTime
  status         ContractRateStatus @default(ACTIVE)
  volume         Int? // expected monthly volume
  notes          String?
  createdById    String
  createdBy      User               @relation("ContractRateCreator", fields: [createdById], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  @@index([customerId])
  @@index([originState, destState, equipmentType])
  @@index([status])
  @@map("contract_rates")
}

enum ContractRateStatus {
  DRAFT
  ACTIVE
  EXPIRED
  SUSPENDED
}

// ─── Routing Guide ──────────────────────────────────────

model RoutingGuide {
  id             String    @id @default(cuid())
  name           String // e.g. "Dallas → LA Dry Van"
  originState    String
  originCity     String?
  destState      String
  destCity       String?
  equipmentType  String
  mode           String    @default("FTL") // FTL, LTL, INTERMODAL
  customerId     String?
  customer       Customer? @relation("CustomerRoutingGuides", fields: [customerId], references: [id], onDelete: SetNull)
  isActive       Boolean   @default(true)
  effectiveDate  DateTime  @default(now())
  expirationDate DateTime?
  notes          String?
  createdById    String
  createdBy      User      @relation("RoutingGuideCreator", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  entries RoutingGuideEntry[]

  @@index([originState, destState, equipmentType])
  @@index([customerId])
  @@index([isActive])
  @@map("routing_guides")
}

model RoutingGuideEntry {
  id             String         @id @default(cuid())
  routingGuideId String
  routingGuide   RoutingGuide   @relation(fields: [routingGuideId], references: [id], onDelete: Cascade)
  rank           Int // 1 = first choice, 2 = fallback, etc.
  carrierId      String
  carrier        CarrierProfile @relation("RoutingGuideCarrier", fields: [carrierId], references: [id])
  targetRate     Float? // negotiated rate for this lane
  rateType       RateType       @default(FLAT)
  fuelSurcharge  Float          @default(0)
  transitDays    Int?
  acceptanceRate Float? // historical acceptance % (auto-updated)
  onTimePct      Float? // historical on-time % (auto-updated)
  totalLoads     Int            @default(0)
  lastUsedAt     DateTime?
  isActive       Boolean        @default(true)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([routingGuideId, rank])
  @@unique([routingGuideId, carrierId])
  @@index([carrierId])
  @@map("routing_guide_entries")
}

// ─── Exception Configuration ────────────────────────────

enum ExceptionSeverity {
  INFO
  WARNING
  CRITICAL
}

model ExceptionConfig {
  id             String            @id @default(cuid())
  code           String            @unique // e.g. "UNCONFIRMED_APPOINTMENT"
  name           String // Display name
  description    String?
  category       String // APPOINTMENT, STOP, ORDER, DOCUMENT, FINANCIAL, CARRIER
  severity       ExceptionSeverity @default(WARNING)
  isEnabled      Boolean           @default(true)
  thresholdValue Float? // e.g. 7 days, $50 variance, etc.
  thresholdUnit  String? // "days", "hours", "dollars", "percent"
  autoResolve    Boolean           @default(false)
  notifyRoles    String[]          @default(["ADMIN", "OPERATIONS"])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  alerts ExceptionAlert[]

  @@index([category])
  @@index([isEnabled])
  @@map("exception_configs")
}

model ExceptionAlert {
  id           String            @id @default(cuid())
  configId     String
  config       ExceptionConfig   @relation(fields: [configId], references: [id], onDelete: Cascade)
  loadId       String?
  invoiceId    String?
  carrierId    String?
  customerId   String?
  entityType   String // LOAD, INVOICE, CARRIER, ORDER
  entityId     String
  status       String            @default("OPEN") // OPEN, ACKNOWLEDGED, RESOLVED, DISMISSED
  severity     ExceptionSeverity
  message      String
  details      Json?
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?             @relation("ExceptionResolver", fields: [resolvedById], references: [id])
  resolvedNote String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([configId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([loadId])
  @@map("exception_alerts")
}

