// ─── Carrier Identity & Fraud Detection ──────────────────────

model CarrierIdentityVerification {
  id                    String   @id @default(cuid())
  carrierId             String   @unique
  carrier               CarrierProfile @relation(fields: [carrierId], references: [id])

  // Photo ID
  photoIdUploaded       Boolean  @default(false)
  photoIdUrl            String?
  photoIdType           PhotoIdType?
  photoIdStatus         PhotoIdStatus @default(PENDING)
  photoIdVerifiedAt     DateTime?
  photoIdVerifiedBy     String?

  // Biometric facial match
  selfieUploaded        Boolean  @default(false)
  selfieUrl             String?
  facialMatchScore      Float?    // 0-100 confidence
  facialMatchStatus     FacialMatchStatus @default(PENDING)
  facialMatchVerifiedAt DateTime?

  // Secretary of State
  sosVerified           Boolean  @default(false)
  sosState              String?
  sosEntityName         String?
  sosFilingNumber       String?
  sosStatus             SosStatus?
  articlesOfIncUrl      String?

  // W-9 IRS TIN
  w9TinVerified         Boolean  @default(false)
  w9TinLastFour         String?
  w9VerifiedAt          DateTime?
  w9TinMatchStatus      TinMatchStatus @default(UNVERIFIED)
  w9TinMatchVerifiedAt  DateTime?
  w9CompanyName         String?
  w9TinFull             String?   // Encrypted, used for IRS match only

  // Email domain analysis
  emailDomainValid      Boolean?
  emailDomainAge        Int?      // days since domain registration
  emailIsDisposable     Boolean?
  emailProvider         EmailProviderType?

  // Phone analysis
  phoneType             PhoneLineType?
  phoneCarrier          String?
  phoneIsVoip           Boolean?

  // Overall score
  identityScore         Int       @default(0) // 0-100
  identityStatus        IdentityStatus @default(UNVERIFIED)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([identityStatus])
  @@map("carrier_identity_verifications")
}

model CarrierFingerprint {
  id          String   @id @default(cuid())
  carrierId   String   @unique
  carrier     CarrierProfile @relation(fields: [carrierId], references: [id])

  phoneHash   String?  // SHA-256 of normalized phone
  emailHash   String?  // SHA-256 of email domain
  addressHash String?  // SHA-256 of normalized address
  einHash     String?  // SHA-256 of EIN/TIN
  ipHash      String?  // SHA-256 of registration IP address
  dotHash     String?  // SHA-256 of DOT number (catches re-registered carriers)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([phoneHash])
  @@index([emailHash])
  @@index([addressHash])
  @@index([einHash])
  @@index([ipHash])
  @@index([dotHash])
  @@map("carrier_fingerprints")
}

model ChameleonMatch {
