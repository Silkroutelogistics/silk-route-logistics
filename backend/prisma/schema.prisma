  updatedAt   DateTime @updatedAt

  rules       TagRule[]
  assignments TagAssignment[]

  @@map("tags")
}

model TagRule {
  id        String   @id @default(cuid())
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  field     String // e.g. "equipmentType", "originState", "rate"
  operator  String // "equals", "contains", "greaterThan", "lessThan", "in"
  value     String // the value to compare against
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tagId])
  @@map("tag_rules")
}

model TagAssignment {
  id         String   @id @default(cuid())
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  entityType String // LOAD, QUOTE, ORDER, INVOICE
  entityId   String
  assignedBy String? // null = auto-assigned by rule
  createdAt  DateTime @default(now())

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("tag_assignments")
}

// ─── Purchase Orders / SKU Tracking ─────────────────────

model PurchaseOrder {
  id             String    @id @default(cuid())
  poNumber       String    @unique
  customerId     String
  customer       Customer  @relation("CustomerPurchaseOrders", fields: [customerId], references: [id], onDelete: Cascade)
  tradingPartner String?
  status         String    @default("OPEN") // OPEN, PARTIAL, CLOSED, CANCELLED
  orderDate      DateTime  @default(now())
  expectedDate   DateTime?
  notes          String?
  createdById    String
  createdBy      User      @relation("POCreator", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lineItems POLineItem[]
  loadLinks POLoadLink[]

  @@index([customerId])
  @@index([status])
  @@map("purchase_orders")
}

model POLineItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  sku             String
  description     String?
  quantity        Int
  unitWeight      Float?
  dimensions      String? // "40L x 48W x 44H in"
  freightClass    String?
  ordered         Int           @default(0)
  shipped         Int           @default(0)
  received        Int           @default(0)
  createdAt       DateTime      @default(now())

  @@index([purchaseOrderId])
  @@map("po_line_items")
}

model POLoadLink {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  loadId          String
  createdAt       DateTime      @default(now())

  @@unique([purchaseOrderId, loadId])
  @@map("po_load_links")
}

// ─── RFP / Bid Management ────────────────────────────────

model RfpBid {
  id             String    @id @default(cuid())
  customerId     String
  customer       Customer  @relation("CustomerRfpBids", fields: [customerId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         RfpStatus @default(OPEN)
  dueDate        DateTime
  lanes          Json // array of { originState, destState, equipmentType, estimatedVolume }
  totalLanes     Int
  respondedLanes Int       @default(0)
  responses      Json? // array of { laneIndex, rate, notes }
  awardedAt      DateTime?
  awardedById    String?
  notes          String?
  createdById    String
  createdBy      User      @relation("RfpCreator", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([customerId])
  @@index([status])
  @@map("rfp_bids")
}

enum RfpStatus {
  DRAFT
  OPEN
  IN_REVIEW
  AWARDED
  DECLINED
  EXPIRED
}

// ─── Webhook Subscriptions ──────────────────────────────

model WebhookEndpoint {
  id          String    @id @default(cuid())
  name        String
  url         String
  secret      String // HMAC signing secret
  events      String[] // e.g. ["LOAD_BOOKED", "LOAD_DELIVERED"]
  headers     Json? // custom headers
  isEnabled   Boolean   @default(true)
  userId      String // who created it
  user        User      @relation("UserWebhooks", fields: [userId], references: [id], onDelete: Cascade)
  failCount   Int       @default(0) // consecutive failures
  lastFiredAt DateTime?
  lastStatus  Int? // last HTTP status
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([userId])
  @@index([isEnabled, deletedAt])
  @@map("webhook_endpoints")
}
