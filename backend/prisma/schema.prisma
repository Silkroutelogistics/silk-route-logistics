  deadheadAvgMiles  Float    @default(0) @map("deadhead_avg_miles")
  competitorDensity String   @default("MEDIUM") @map("competitor_density") // HIGH, MEDIUM, LOW
  seasonality       Json?    // {jan: 1.1, feb: 0.9, ...}
